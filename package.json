{
  "name": "clip",
  "version": "0.2.0",
  "private": true,
  "main": "electron/main.dist.js",
  "description": "AI clipping app — turn long recordings into viral short-form clips",
  "author": "Rubruby420",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "electron:dev": "electron .",
    "electron:bundle": "esbuild electron/main.js --bundle --platform=node --target=node18 --external:electron --log-level=warning --outfile=electron/main.dist.js",
    "electron:prepare": "next build && node scripts/prepare-electron-build.js",
    "electron:pack": "npm run electron:prepare && npm run electron:bundle && electron-builder --dir",
    "electron:build": "npm run electron:prepare && npm run electron:bundle && electron-builder --win --publish never",
    "electron:release": "npm run electron:prepare && npm run electron:bundle && electron-builder --win --publish always"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slider": "^1.2.1",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.3",
    "assemblyai": "^4.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ffmpeg-static": "^5.2.0",
    "konva": "^9.3.16",
    "lucide-react": "^0.468.0",
    "next": "^15.3.2",
    "openai": "^4.77.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^18.2.10",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@types/ffmpeg-static": "^3.0.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "esbuild": "^0.24.2",
    "eslint": "^8",
    "eslint-config-next": "^15.3.2",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
